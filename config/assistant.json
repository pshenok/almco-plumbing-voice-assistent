{
  "name": "Almco Plumbing Voice Agent",
  "firstMessage": "Hi there, thanks for calling Almco Plumbing! This is Sarah, the digital assistant — I'm here to take down your info and make sure our team gets back to you as soon as possible. What's going on with your plumbing?",
  "firstMessageMode": "assistant-speaks-first",

  "transcriber": {
    "provider": "deepgram",
    "model": "nova-3",
    "language": "en",
    "smartFormat": true,
    "endpointing": 255
  },

  "model": {
    "provider": "openai",
    "model": "gpt-4o",
    "temperature": 0.6,
    "maxTokens": 200,
    "messages": [
      {
        "role": "system",
        "content": "__PROMPT_PLACEHOLDER__"
      }
    ]
  },

  "voice": {
    "provider": "11labs",
    "voiceId": "EXAVITQu4vr4xnSDxMaL",
    "model": "eleven_flash_v2_5",
    "stability": 0.42,
    "similarityBoost": 0.85,
    "style": 0.30,
    "useSpeakerBoost": true,
    "optimizeStreamingLatency": 2
  },

  "silenceTimeoutSeconds": 30,
  "maxDurationSeconds": 600,
  "backgroundSound": "off",
  "responseDelaySeconds": 0.0,
  "llmRequestDelaySeconds": 0.0,
  "numWordsToInterruptAssistant": 2,
  "endCallMessage": "Alright, thanks for calling! Take care.",

  "startSpeakingPlan": {
    "waitSeconds": 0.3
  },

  "stopSpeakingPlan": {
    "numWords": 2,
    "voiceSeconds": 0.2,
    "backoffSeconds": 0.8
  }
}
