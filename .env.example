# VAPI API Key (get from https://dashboard.vapi.ai)
VAPI_API_KEY=your_api_key_here

# Existing assistant ID (filled after first setup)
VAPI_ASSISTANT_ID=

# Phone number ID (filled after first setup)
VAPI_PHONE_ID=

# Retell AI (get from https://dashboard.retellai.com)
RETELL_API_KEY=your_retell_api_key_here

# Retell agent/phone IDs (filled after first setup)
RETELL_AGENT_ID=
RETELL_LLM_ID=
RETELL_PHONE_ID=
